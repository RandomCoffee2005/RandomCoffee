FROM python:3.14-alpine3.23
RUN --mount=type=bind,source=frontend/requirements.txt,target=/tmp/requirements.txt \
    pip install --break-system-packages --no-cache -r /tmp/requirements.txt
RUN mkdir /app
WORKDIR /app
COPY src/front /app

RUN adduser -H -h /app -D -u 2000 randomcoffee randomcoffee
USER randomcoffee

EXPOSE 8080

ENTRYPOINT ["streamlit", "run", "app.py", "--server.port=8080"]
